{
  "name": "daybook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "today": "node scripts/today.mjs",
    "serve": "python3 -m http.server 5177 --bind 127.0.0.1",
    "dev": "npm run serve",
    "check": "node scripts/check-demo.mjs",
    "check:jsonl": "node scripts/validate-jsonl.mjs data/events.sample.jsonl",
    "check:security": "node scripts/check-security.mjs",
    "ingest:local": "node scripts/ingest-local.mjs",
    "check:local": "node scripts/validate-jsonl.mjs data/events.local.jsonl",
    "check:quality": "node scripts/check-report-quality.mjs",
    "check:taxonomy": "node scripts/check-project-taxonomy.mjs",
    "report:human": "node scripts/ingest-local.mjs && node scripts/generate-human-report.mjs",
    "audit:quality": "node scripts/report-quality.mjs audit",
    "report:recent": "node scripts/report-quality.mjs recent",
    "audit:taxonomy": "node scripts/project-taxonomy-audit.mjs",
    "build:standalone": "node scripts/build-standalone.mjs",
    "shots": "node scripts/verify-playwright.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
